{
  "id": "controller.rollback_branch",
  "title": "Agent controller routes failed verification into explicit rollback branch",
  "category": "controller",
  "workspace": {
    "files": [
      { "path": "src/rollback-target.mjs", "content": "export const value = 1;\n" }
    ]
  },
  "context": {
    "config": {
      "autoActionCommands": { "allowlist": ["node --check"], "denylist": ["rm", "del", "git push", "git tag", "npm publish"] },
      "autoActions": { "autoRepairEnabled": false }
    },
    "taskScope": { "allowedFiles": ["src/rollback-target.mjs"], "maxChangedFiles": 1 },
    "actionPlan": {
      "id": "bench:controller_rollback_branch",
      "type": "action_plan",
      "riskTier": "R2",
      "plan": {
        "actionType": "apply_patch_sandboxed",
        "fileWrites": [
          { "path": "src/rollback-target.mjs", "content": "export const broken = ;\n" }
        ]
      },
      "verification": { "commands": ["node --check src/rollback-target.mjs"], "metrics": ["verification_commands_pass", "rollback_clean"] }
    }
  },
  "steps": [
    {
      "type": "run_agent_controller",
      "name": "controller_routes_to_rollback",
      "input": {
        "title": "controller rollback branch benchmark",
        "nodes": [
          { "id": "observe", "type": "ObserveNode" },
          { "id": "plan", "type": "PlanNode" },
          { "id": "policy", "type": "PolicyNode" },
          { "id": "scope", "type": "ScopeNode" },
          { "id": "execute", "type": "ExecuteNode" },
          { "id": "verify", "type": "VerifyNode" },
          { "id": "rollback", "type": "RollbackNode" },
          { "id": "feedback", "type": "FeedbackNode" },
          { "id": "finalize", "type": "FinalizeNode" }
        ]
      },
      "expectStatus": "completed"
    },
    { "type": "assert_last_result", "path": "state.state", "equals": "completed" },
    { "type": "assert_file", "path": "src/rollback-target.mjs", "contains": "export const value = 1;" }
  ]
}
