node_modules/
*.log
*.tmp
.DS_Store
Thumbs.db
.idea/
.vscode/
_tmp_keys.mjs

# v5 build artifacts (generated by `npm run build`; published as a zip, not committed)
dist/
release/

# Local embedding model weights are large binaries and must never be committed
# (fetched on demand, copied into dist/assets at build time).
assets/models/
*.onnx
*.safetensors
*.bin

# Benchmark reports are generated by `npm run benchmark` into ./benchmark-results.
# They carry per-run timestamps and latency numbers, so committing them produces
# noisy diffs and dirties the working tree on every run. The tracked input is the
# baseline under benchmarks/; the generated report is derivative and local-only.
benchmark-results/
